{% extends 'base.html.twig' %}

{% block title %}Classement petit toureur - Mon Petit Tour{% endblock %}

{% block body %}
    <section class="mx-auto max-w-6xl px-4 py-10">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-sm font-bold uppercase tracking-wide text-emerald-700">Classement global</p>
                <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-950">Classement petit toureur</h1>
            </div>
            <p class="text-sm font-semibold text-slate-600">{{ standings|length }} équipes classées</p>
        </div>

        <div class="mt-8 overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <table class="w-full text-left text-sm">
                <thead class="bg-slate-100 text-xs font-bold uppercase tracking-wide text-slate-600">
                    <tr>
                        <th class="px-4 py-3">Rang</th>
                        <th class="px-4 py-3">Équipe</th>
                        <th class="px-4 py-3">Manager</th>
                        <th class="px-4 py-3">Budget</th>
                        <th class="px-4 py-3">Temps cumulé</th>
                        <th class="px-4 py-3">Écart</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    {% for standing in standings %}
                        <tr class="{{ standing.isCurrentUser ? 'border-l-4 border-emerald-600 bg-emerald-50/80' : '' }}">
                            <td class="px-4 py-3 font-extrabold">#{{ standing.rank }}</td>
                            <td class="px-4 py-3 font-bold">{{ standing.teamName }}</td>
                            <td class="px-4 py-3">{{ standing.ownerUsername }}</td>
                            <td class="px-4 py-3 text-slate-600">{{ standing.spentBudgetInEuros|number_format(0, ',', ' ') }} €</td>
                            <td class="px-4 py-3 font-semibold">{{ standing.formattedTotalTime }}</td>
                            <td class="px-4 py-3 font-semibold text-slate-600">{{ standing.formattedGap }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td class="px-4 py-6 text-sm font-semibold text-slate-600" colspan="6">Aucune équipe composée pour le moment.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
