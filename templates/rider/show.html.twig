{% extends 'base.html.twig' %}

{% block title %}{{ rider.name }} - {{ 'app.name'|trans }}{% endblock %}

{% block body %}
    <section class="mx-auto max-w-4xl px-4 py-10">
        <a class="text-sm font-bold text-emerald-700 hover:text-emerald-900" href="{{ path('rider_index') }}">{{ 'rider.back_to_list'|trans }}</a>

        <article class="mt-6 rounded-lg border border-slate-200 bg-white p-8 shadow-sm">
            <p class="text-sm font-bold uppercase tracking-wide text-emerald-700">{{ rider.realTeam }}</p>
            <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-slate-950">
                {% if rider.nationalityFlag %}<span aria-hidden="true">{{ rider.nationalityFlag }}</span>{% endif %}
                {{ rider.name }}
            </h1>
            <dl class="mt-8 grid gap-5 sm:grid-cols-2">
                <div>
                    <dt class="text-sm font-semibold text-slate-600">{{ 'rider.nationality'|trans }}</dt>
                    <dd class="mt-1 text-lg font-bold text-slate-950">
                        {% if rider.nationalityFlag %}<span aria-hidden="true">{{ rider.nationalityFlag }}</span>{% endif %}
                        {{ rider.nationality }}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm font-semibold text-slate-600">{{ 'rider.market_value'|trans }}</dt>
                    <dd class="mt-1 text-lg font-bold text-slate-950">{{ rider.marketValueInEuros|number_format(0, ',', ' ') }} €</dd>
                </div>
                <div>
                    <dt class="text-sm font-semibold text-slate-600">{{ 'rider.specialty_label'|trans }}</dt>
                    <dd class="mt-1 text-lg font-bold text-slate-950">{{ rider.specialty ?? 'rider.specialty.polyvalent'|trans }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-semibold text-slate-600">{{ 'table.status'|trans }}</dt>
                    <dd class="mt-1">
                        {% if rider.isStillRacing %}
                            <span class="rounded-md bg-emerald-50 px-3 py-1 text-sm font-extrabold uppercase text-emerald-800">{{ 'rider.status.racing'|trans }}</span>
                        {% else %}
                            <span class="rounded-md bg-rose-100 px-3 py-1 text-sm font-extrabold uppercase text-rose-800">{{ 'rider.status.abandoned'|trans }}</span>
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm font-semibold text-slate-600">{{ 'table.cumulative_time'|trans }}</dt>
                    <dd class="mt-1 text-lg font-bold text-slate-950">{{ rider.formattedTotalTime|trans }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-semibold text-slate-600">{{ 'rider.cumulative_gap'|trans }}</dt>
                    <dd class="mt-1 text-lg font-bold text-slate-950">{{ rider.formattedTotalGap }}</dd>
                </div>
            </dl>
        </article>
    </section>
{% endblock %}
