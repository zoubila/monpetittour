{% extends 'base.html.twig' %}

{% block title %}{{ rider.name }} - Mon Petit Tour{% endblock %}

{% block body %}
    <section class="mx-auto max-w-4xl px-4 py-10">
        <a class="text-sm font-bold text-emerald-700 hover:text-emerald-900" href="{{ path('rider_index') }}">Retour aux coureurs</a>

        <article class="mt-6 rounded-lg border border-slate-200 bg-white p-8 shadow-sm">
            <p class="text-sm font-bold uppercase tracking-wide text-emerald-700">{{ rider.realTeam }}</p>
            <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-slate-950">
                {% if rider.nationalityFlag %}<span aria-hidden="true">{{ rider.nationalityFlag }}</span>{% endif %}
                {{ rider.name }}
            </h1>
            <dl class="mt-8 grid gap-5 sm:grid-cols-2">
                <div>
                    <dt class="text-sm font-semibold text-slate-600">Nationalité</dt>
                    <dd class="mt-1 text-lg font-bold text-slate-950">
                        {% if rider.nationalityFlag %}<span aria-hidden="true">{{ rider.nationalityFlag }}</span>{% endif %}
                        {{ rider.nationality }}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm font-semibold text-slate-600">Valeur marchande</dt>
                    <dd class="mt-1 text-lg font-bold text-slate-950">{{ rider.marketValueInEuros|number_format(0, ',', ' ') }} €</dd>
                </div>
                <div>
                    <dt class="text-sm font-semibold text-slate-600">Spécialité</dt>
                    <dd class="mt-1 text-lg font-bold text-slate-950">{{ rider.specialty ?? 'Profil polyvalent' }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-semibold text-slate-600">Statut</dt>
                    <dd class="mt-1">
                        {% if rider.isStillRacing %}
                            <span class="rounded-md bg-emerald-50 px-3 py-1 text-sm font-extrabold uppercase text-emerald-800">En course</span>
                        {% else %}
                            <span class="rounded-md bg-rose-100 px-3 py-1 text-sm font-extrabold uppercase text-rose-800">Abandon</span>
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm font-semibold text-slate-600">Temps cumulé</dt>
                    <dd class="mt-1 text-lg font-bold text-slate-950">{{ rider.formattedTotalTime }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-semibold text-slate-600">Écart cumulé</dt>
                    <dd class="mt-1 text-lg font-bold text-slate-950">{{ rider.formattedTotalGap }}</dd>
                </div>
            </dl>
        </article>
    </section>
{% endblock %}
