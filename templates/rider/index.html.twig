{% extends 'base.html.twig' %}

{% block title %}Coureurs - Mon Petit Tour{% endblock %}

{% block body %}
    <section class="mx-auto max-w-6xl px-4 py-10">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-sm font-bold uppercase tracking-wide text-emerald-700">Startlist fixtures</p>
                <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-950">Coureurs disponibles</h1>
            </div>
            <p class="text-sm font-semibold text-slate-600">{{ riders|length }} coureurs chargés</p>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-2">
            {% for rider in riders %}
                <a class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm hover:border-emerald-600" href="{{ path('rider_show', { slug: rider.slug }) }}">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <h2 class="text-lg font-extrabold text-slate-950">{{ rider.name }}</h2>
                            <p class="mt-1 text-sm font-medium text-slate-600">{{ rider.realTeam }} · {{ rider.nationality }}</p>
                        </div>
                        <p class="shrink-0 rounded-md bg-emerald-50 px-3 py-1 text-sm font-extrabold text-emerald-800">{{ rider.marketValueInEuros|number_format(0, ',', ' ') }} €</p>
                    </div>
                    <p class="mt-4 text-sm font-semibold text-slate-700">{{ rider.specialty ?? 'Profil polyvalent' }}</p>
                </a>
            {% endfor %}
        </div>
    </section>
{% endblock %}
