{% extends 'base.html.twig' %}

{% block title %}{{ league.name }} - {{ 'app.name'|trans }}{% endblock %}

{% block body %}
    <section class="mx-auto max-w-6xl px-4 py-10">
        <a class="text-sm font-bold text-emerald-700 hover:text-emerald-900" href="{{ path('home') }}">{{ 'nav.back_home'|trans }}</a>
        <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-sm font-bold uppercase tracking-wide text-emerald-700">{{ 'league.eyebrow'|trans }}</p>
                <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-950">{{ league.name }}</h1>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                <p class="rounded-md bg-emerald-50 px-3 py-2 text-sm font-extrabold text-emerald-800">{{ 'league.code'|trans({'%code%': league.code}) }}</p>
                <a class="rounded-md bg-slate-950 px-3 py-2 text-sm font-bold text-white hover:bg-slate-800" href="{{ path('league_team_compositions', { id: app.request.attributes.get('id') }) }}">{{ 'league.compositions.link'|trans }}</a>
            </div>
        </div>

        <section class="mt-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-extrabold tracking-tight text-slate-950">{{ 'league.general_standings'|trans }}</h2>
            <div class="mt-5 overflow-hidden rounded-lg border border-slate-200">
                <table class="w-full text-left text-sm">
                    <thead class="bg-slate-100 text-xs font-bold uppercase tracking-wide text-slate-600">
                        <tr>
                            <th class="px-4 py-3">{{ 'table.rank'|trans }}</th>
                            <th class="px-4 py-3">{{ 'table.team'|trans }}</th>
                            <th class="px-4 py-3">{{ 'table.manager'|trans }}</th>
                            <th class="px-4 py-3">{{ 'table.total_time'|trans }}</th>
                            <th class="px-4 py-3">{{ 'table.gap'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                        {% for standing in league.generalStandings %}
                            <tr class="{{ standing.isCurrentUser ? 'border-l-4 border-emerald-600 bg-emerald-50/80' : '' }}">
                                <td class="px-4 py-3 font-extrabold">#{{ standing.rank }}</td>
                                <td class="px-4 py-3 font-bold">{{ standing.teamName }}</td>
                                <td class="px-4 py-3">{{ standing.ownerUsername }}</td>
                                <td class="px-4 py-3 font-semibold">{{ standing.formattedTotalTime }}</td>
                                <td class="px-4 py-3 font-semibold text-slate-600">{{ standing.formattedGap }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <div class="mt-8 space-y-8">
            {% for stageDashboard in league.stages %}
                <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                        <div>
                            <p class="text-sm font-bold uppercase tracking-wide text-emerald-700">{{ 'stage.number'|trans({'%number%': stageDashboard.stage.number}) }}</p>
                            <h2 class="mt-1 text-2xl font-extrabold tracking-tight text-slate-950">{{ stageDashboard.stage.startLocation }} - {{ stageDashboard.stage.finishLocation }}</h2>
                        </div>
                        <div class="flex flex-wrap items-center gap-3 text-sm font-semibold text-slate-600">
                            <span>{{ stageDashboard.stage.distanceInKilometers }} km</span>
                            {% if stageDashboard.stage.mapPath %}
                                <button
                                    class="rounded-md border border-emerald-200 px-3 py-2 text-sm font-bold text-emerald-800 hover:border-emerald-600 hover:bg-emerald-50"
                                    type="button"
                                    data-stage-map-open
                                    data-stage-map-src="{{ stageDashboard.stage.mapPath }}"
                                    data-stage-map-title="{{ 'stage.map_title'|trans({'%number%': stageDashboard.stage.number, '%start%': stageDashboard.stage.startLocation, '%finish%': stageDashboard.stage.finishLocation}) }}"
                                >
                                    {{ 'stage.view_map'|trans }}
                                </button>
                            {% endif %}
                        </div>
                    </div>

                    <div class="mt-6 grid gap-6 lg:grid-cols-2">
                        <div>
                            <h3 class="text-lg font-extrabold">{{ 'league.stage_team_standings'|trans }}</h3>
                            <div class="mt-3 overflow-hidden rounded-lg border border-slate-200">
                                <table class="w-full text-left text-sm">
                                    <thead class="bg-slate-100 text-xs font-bold uppercase tracking-wide text-slate-600">
                                        <tr>
                                            <th class="px-4 py-3">{{ 'table.rank'|trans }}</th>
                                            <th class="px-4 py-3">{{ 'table.team'|trans }}</th>
                                            <th class="px-4 py-3">{{ 'table.time'|trans }}</th>
                                            <th class="px-4 py-3">{{ 'table.gap'|trans }}</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-200">
                                        {% for standing in stageDashboard.teamStandings %}
                                            <tr class="{{ standing.isCurrentUser ? 'border-l-4 border-emerald-600 bg-emerald-50/80' : '' }}">
                                                <td class="px-4 py-3 font-extrabold">#{{ standing.rank }}</td>
                                                <td class="px-4 py-3 font-bold">{{ standing.teamName }}</td>
                                                <td class="px-4 py-3 font-semibold">{{ standing.formattedTotalTime }}</td>
                                                <td class="px-4 py-3 font-semibold text-slate-600">{{ standing.formattedGap }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div>
                            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                                <div>
                                    <h3 class="text-lg font-extrabold">{{ 'league.stage_rider_standings'|trans }}</h3>
                                    <p class="mt-1 text-xs font-semibold text-slate-600">{{ 'rider.visible_count_html'|trans({'%count%': '<span data-stage-rider-visible-count>' ~ stageDashboard.riderStandings|length ~ '</span>'})|raw }}</p>
                                </div>
                                <label class="inline-flex cursor-pointer items-center gap-3 text-sm font-bold text-slate-700">
                                    <input class="peer sr-only" type="checkbox" data-stage-rider-team-toggle>
                                    <span class="h-6 w-11 rounded-full bg-slate-300 p-1 transition peer-checked:bg-emerald-700">
                                        <span class="block h-4 w-4 rounded-full bg-white transition peer-checked:translate-x-5"></span>
                                    </span>
                                    {{ 'rider.my_riders'|trans }}
                                </label>
                            </div>
                            <div class="mt-3 max-h-96 overflow-auto rounded-lg border border-slate-200" data-stage-rider-ranking>
                                <table class="w-full text-left text-sm">
                                    <thead class="bg-slate-100 text-xs font-bold uppercase tracking-wide text-slate-600">
                                        <tr>
                                            <th class="px-4 py-3">{{ 'table.rank'|trans }}</th>
                                            <th class="px-4 py-3">{{ 'table.rider'|trans }}</th>
                                            <th class="px-4 py-3">{{ 'table.time'|trans }}</th>
                                            <th class="px-4 py-3">{{ 'table.gap'|trans }}</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-200">
                                        {% for standing in stageDashboard.riderStandings %}
                                            <tr
                                                class="{{ standing.isInCurrentUserTeam ? 'border-l-4 border-emerald-600 bg-emerald-50/80' : '' }}"
                                                data-stage-rider-row
                                                data-current-user-rider="{{ standing.isInCurrentUserTeam ? '1' : '0' }}"
                                            >
                                                <td class="px-4 py-3 font-extrabold">#{{ standing.rank }}</td>
                                                <td class="px-4 py-3">
                                                    <span class="block font-bold">
                                                        {% if standing.nationalityFlag %}<span aria-hidden="true">{{ standing.nationalityFlag }}</span>{% endif %}
                                                        {{ standing.riderName }}
                                                    </span>
                                                    <span class="block text-xs text-slate-600">{{ standing.realTeam }}</span>
                                                </td>
                                                <td class="px-4 py-3 font-semibold">{{ standing.time }}</td>
                                                <td class="px-4 py-3 font-semibold text-slate-600">{{ standing.gap }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </section>
            {% endfor %}
        </div>
    </section>

    <div class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/70 p-4" data-stage-map-modal>
        <div class="w-full max-w-5xl rounded-lg bg-white p-4 shadow-xl">
            <div class="flex items-center justify-between gap-4">
                <h2 class="text-lg font-extrabold text-slate-950" data-stage-map-title></h2>
                <button
                    class="rounded-md border border-slate-300 px-3 py-2 text-sm font-bold text-slate-800 hover:border-emerald-600 hover:text-emerald-700"
                    type="button"
                    data-stage-map-close
                >
                    {{ 'modal.close'|trans }}
                </button>
            </div>
            <img class="mt-4 max-h-[75vh] w-full rounded-md object-contain" src="" alt="" data-stage-map-image>
        </div>
    </div>

    <script>
        (() => {
            const modal = document.querySelector('[data-stage-map-modal]');
            if (!modal) {
                return;
            }

            const image = modal.querySelector('[data-stage-map-image]');
            const title = modal.querySelector('[data-stage-map-title]');
            const closeButtons = modal.querySelectorAll('[data-stage-map-close]');

            const close = () => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                image.setAttribute('src', '');
                image.setAttribute('alt', '');
            };

            document.querySelectorAll('[data-stage-map-open]').forEach((button) => {
                button.addEventListener('click', () => {
                    const stageTitle = button.dataset.stageMapTitle || '{{ 'stage.map_fallback_title'|trans|e('js') }}';

                    title.textContent = stageTitle;
                    image.setAttribute('src', button.dataset.stageMapSrc || '');
                    image.setAttribute('alt', stageTitle);
                    modal.classList.remove('hidden');
                    modal.classList.add('flex');
                });
            });

            closeButtons.forEach((button) => button.addEventListener('click', close));
            modal.addEventListener('click', (event) => {
                if (event.target === modal) {
                    close();
                }
            });
            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
                    close();
                }
            });
        })();

        (() => {
            document.querySelectorAll('[data-stage-rider-ranking]').forEach((ranking) => {
                const wrapper = ranking.closest('div')?.parentElement;
                const toggle = wrapper?.querySelector('[data-stage-rider-team-toggle]');
                const count = wrapper?.querySelector('[data-stage-rider-visible-count]');
                const rows = Array.from(ranking.querySelectorAll('[data-stage-rider-row]'));

                if (!toggle || !count || rows.length === 0) {
                    return;
                }

                const refresh = () => {
                    let visibleCount = 0;

                    rows.forEach((row) => {
                        const shouldShow = !toggle.checked || row.dataset.currentUserRider === '1';

                        row.classList.toggle('hidden', !shouldShow);
                        if (shouldShow) {
                            visibleCount += 1;
                        }
                    });

                    count.textContent = visibleCount.toString();
                };

                toggle.addEventListener('change', refresh);
                refresh();
            });
        })();
    </script>
{% endblock %}
