{% extends 'base.html.twig' %}

{% block title %}{{ league.name }} - Mon Petit Tour{% endblock %}

{% block body %}
    <section class="mx-auto max-w-6xl px-4 py-10">
        <a class="text-sm font-bold text-emerald-700 hover:text-emerald-900" href="{{ path('home') }}">Retour accueil</a>
        <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-sm font-bold uppercase tracking-wide text-emerald-700">Ligue</p>
                <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-950">{{ league.name }}</h1>
            </div>
            <p class="rounded-md bg-emerald-50 px-3 py-2 text-sm font-extrabold text-emerald-800">Code {{ league.code }}</p>
        </div>

        <section class="mt-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-extrabold tracking-tight text-slate-950">Classement général</h2>
            <div class="mt-5 overflow-hidden rounded-lg border border-slate-200">
                <table class="w-full text-left text-sm">
                    <thead class="bg-slate-100 text-xs font-bold uppercase tracking-wide text-slate-600">
                        <tr>
                            <th class="px-4 py-3">Rang</th>
                            <th class="px-4 py-3">Équipe</th>
                            <th class="px-4 py-3">Manager</th>
                            <th class="px-4 py-3">Temps total</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                        {% for standing in league.generalStandings %}
                            <tr>
                                <td class="px-4 py-3 font-extrabold">#{{ standing.rank }}</td>
                                <td class="px-4 py-3 font-bold">{{ standing.teamName }}</td>
                                <td class="px-4 py-3">{{ standing.ownerUsername }}</td>
                                <td class="px-4 py-3 font-semibold">{{ standing.formattedTotalTime }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <div class="mt-8 space-y-8">
            {% for stageDashboard in league.stages %}
                <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                        <div>
                            <p class="text-sm font-bold uppercase tracking-wide text-emerald-700">Étape {{ stageDashboard.stage.number }}</p>
                            <h2 class="mt-1 text-2xl font-extrabold tracking-tight text-slate-950">{{ stageDashboard.stage.startLocation }} - {{ stageDashboard.stage.finishLocation }}</h2>
                        </div>
                        <p class="text-sm font-semibold text-slate-600">{{ stageDashboard.stage.distanceInKilometers }} km · {{ stageDashboard.stage.positiveElevationInMeters }} m D+</p>
                    </div>

                    <div class="mt-6 grid gap-6 lg:grid-cols-2">
                        <div>
                            <h3 class="text-lg font-extrabold">Classement users</h3>
                            <div class="mt-3 overflow-hidden rounded-lg border border-slate-200">
                                <table class="w-full text-left text-sm">
                                    <thead class="bg-slate-100 text-xs font-bold uppercase tracking-wide text-slate-600">
                                        <tr>
                                            <th class="px-4 py-3">Rang</th>
                                            <th class="px-4 py-3">Équipe</th>
                                            <th class="px-4 py-3">Temps</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-200">
                                        {% for standing in stageDashboard.teamStandings %}
                                            <tr>
                                                <td class="px-4 py-3 font-extrabold">#{{ standing.rank }}</td>
                                                <td class="px-4 py-3 font-bold">{{ standing.teamName }}</td>
                                                <td class="px-4 py-3 font-semibold">{{ standing.formattedTotalTime }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div>
                            <h3 class="text-lg font-extrabold">Classement riders</h3>
                            <div class="mt-3 max-h-96 overflow-auto rounded-lg border border-slate-200">
                                <table class="w-full text-left text-sm">
                                    <thead class="bg-slate-100 text-xs font-bold uppercase tracking-wide text-slate-600">
                                        <tr>
                                            <th class="px-4 py-3">Rang</th>
                                            <th class="px-4 py-3">Coureur</th>
                                            <th class="px-4 py-3">Temps</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-200">
                                        {% for standing in stageDashboard.riderStandings %}
                                            <tr>
                                                <td class="px-4 py-3 font-extrabold">#{{ standing.rank }}</td>
                                                <td class="px-4 py-3">
                                                    <span class="block font-bold">{{ standing.riderName }}</span>
                                                    <span class="block text-xs text-slate-600">{{ standing.realTeam }}</span>
                                                </td>
                                                <td class="px-4 py-3 font-semibold">{{ standing.time }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </section>
            {% endfor %}
        </div>
    </section>
{% endblock %}
