<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}{{ 'app.name'|trans }}{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <script>
            window.tailwind = window.tailwind || {};
            window.tailwind.config = { darkMode: 'class' };
            (() => {
                const storedTheme = localStorage.getItem('theme');
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                const theme = storedTheme || (prefersDark ? 'dark' : 'light');

                document.documentElement.classList.toggle('dark', theme === 'dark');
            })();
        </script>
        <script src="https://cdn.tailwindcss.com"></script>
        <style>
            .dark body {
                color: #f8fafc;
            }

            body {
                background-image: linear-gradient(rgba(248, 250, 252, 0.72), rgba(248, 250, 252, 0.72)), url('{{ asset('UI/background.png') }}');
                background-attachment: fixed;
                background-position: center;
                background-size: cover;
            }

            .dark body {
                background-image: linear-gradient(rgba(2, 6, 23, 0.78), rgba(2, 6, 23, 0.78)), url('{{ asset('UI/background.png') }}');
            }

            .dark .bg-white,
            .dark .bg-white\/95 {
                background-color: #0f172a !important;
            }

            .dark .bg-slate-50 {
                background-color: #020617 !important;
            }

            .dark .bg-slate-100 {
                background-color: #1e293b !important;
            }

            .dark .bg-emerald-50,
            .dark .bg-emerald-50\/80,
            .dark .bg-emerald-50\/90 {
                background-color: rgba(6, 78, 59, 0.45) !important;
            }

            .dark .text-slate-950,
            .dark .text-slate-900,
            .dark .text-slate-800 {
                color: #f8fafc !important;
            }

            .dark .text-slate-700,
            .dark .text-slate-600 {
                color: #cbd5e1 !important;
            }

            .dark .border-slate-100,
            .dark .border-slate-200,
            .dark .border-slate-300 {
                border-color: #334155 !important;
            }

            .dark input,
            .dark select {
                background-color: #020617;
                color: #f8fafc;
            }

            input.peer:checked + span > span {
                transform: translateX(1.25rem);
            }

            input[data-theme-toggle]:checked + span > span {
                transform: translateX(1.25rem);
            }
        </style>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="min-h-screen text-slate-950">
        {% if app.user %}
            <header class="border-b border-slate-200 bg-white/95 backdrop-blur">
                <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
                    <a class="flex items-center" href="{{ path('home') }}" aria-label="{{ 'nav.home_aria'|trans }}">
                        <img class="h-14 w-auto" src="{{ asset('UI/logo.png') }}" alt="{{ 'app.name'|trans }}">
                    </a>
                    <nav class="flex items-center gap-4 text-sm font-semibold text-slate-700">
                        <a class="hover:text-emerald-700" href="{{ path('home') }}">{{ 'nav.home'|trans }}</a>
                        <a class="hover:text-emerald-700" href="{{ path('rider_index') }}">{{ 'nav.riders'|trans }}</a>
                        <a class="hover:text-emerald-700" href="{{ path('official_rider_classification') }}">{{ 'nav.official_classification'|trans }}</a>
                        <a class="hover:text-emerald-700" href="{{ path('global_fantasy_team_classification') }}">{{ 'nav.petit_toureur'|trans }}</a>
                        <div class="flex items-center gap-2">
                            {% set locales = {
                                fr: '🇫🇷',
                                en: '🇬🇧',
                                es: '🇪🇸',
                                pt: '🇵🇹'
                            } %}
                            {% for locale, flag in locales %}
                                <a
                                    class="rounded px-1.5 py-1 text-base hover:bg-emerald-50 {{ app.request.locale == locale ? 'bg-emerald-50 ring-1 ring-emerald-600' : '' }}"
                                    href="{{ path('locale_switch', { locale: locale }) }}"
                                    title="{{ ('language.' ~ locale)|trans }}"
                                    aria-label="{{ ('language.' ~ locale)|trans }}"
                                >{{ flag }}</a>
                            {% endfor %}
                        </div>
                        <label class="inline-flex cursor-pointer items-center gap-2" title="{{ 'theme.toggle'|trans }}">
                            <input class="sr-only" type="checkbox" data-theme-toggle aria-label="{{ 'theme.toggle'|trans }}">
                            <span class="h-6 w-11 rounded-full bg-slate-300 p-1 transition">
                                <span class="block h-4 w-4 rounded-full bg-white transition"></span>
                            </span>
                            <span data-theme-toggle-label>{{ 'theme.dark'|trans }}</span>
                        </label>
                        <a class="rounded-md border border-slate-300 px-3 py-2 hover:border-emerald-600 hover:text-emerald-700" href="{{ path('app_logout') }}">{{ 'nav.logout'|trans }}</a>
                    </nav>
                </div>
            </header>
        {% else %}
            <div class="fixed right-4 top-4 z-50 flex items-center gap-2">
                {% set locales = {
                    fr: '🇫🇷',
                    en: '🇬🇧',
                    es: '🇪🇸',
                    pt: '🇵🇹'
                } %}
                <div class="flex rounded-md border border-slate-300 bg-white px-2 py-1 shadow-sm">
                    {% for locale, flag in locales %}
                        <a
                            class="rounded px-1.5 py-1 text-base hover:bg-emerald-50 {{ app.request.locale == locale ? 'bg-emerald-50 ring-1 ring-emerald-600' : '' }}"
                            href="{{ path('locale_switch', { locale: locale }) }}"
                            title="{{ ('language.' ~ locale)|trans }}"
                            aria-label="{{ ('language.' ~ locale)|trans }}"
                        >{{ flag }}</a>
                    {% endfor %}
                </div>
                <label class="inline-flex cursor-pointer items-center gap-2 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-bold text-slate-800 shadow-sm hover:border-emerald-600 hover:text-emerald-700" title="{{ 'theme.toggle'|trans }}">
                    <input class="sr-only" type="checkbox" data-theme-toggle aria-label="{{ 'theme.toggle'|trans }}">
                    <span class="h-6 w-11 rounded-full bg-slate-300 p-1 transition">
                        <span class="block h-4 w-4 rounded-full bg-white transition"></span>
                    </span>
                    <span data-theme-toggle-label>{{ 'theme.dark'|trans }}</span>
                </label>
            </div>
        {% endif %}
        <main>
            {% block body %}{% endblock %}
        </main>
        <script>
            (() => {
                const toggles = document.querySelectorAll('[data-theme-toggle]');
                const labels = document.querySelectorAll('[data-theme-toggle-label]');

                if (toggles.length === 0) {
                    return;
                }

                const refreshToggles = () => {
                    const isDark = document.documentElement.classList.contains('dark');
                    toggles.forEach((toggle) => {
                        toggle.checked = isDark;
                    });
                    labels.forEach((label) => {
                        label.textContent = isDark ? '{{ 'theme.light'|trans|e('js') }}' : '{{ 'theme.dark'|trans|e('js') }}';
                    });
                };

                toggles.forEach((toggle) => {
                    toggle.addEventListener('change', () => {
                        const isDark = toggle.checked;
                        document.documentElement.classList.toggle('dark', isDark);
                        localStorage.setItem('theme', isDark ? 'dark' : 'light');
                        refreshToggles();
                    });
                });

                refreshToggles();
            })();
        </script>
    </body>
</html>
