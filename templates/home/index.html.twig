{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans }} - {{ 'app.name'|trans }}{% endblock %}

{% block body %}
    <section>
        <div class="mx-auto max-w-6xl px-4 py-12">
            <h1 class="text-sm font-bold uppercase tracking-wide text-emerald-700">{{ 'home.eyebrow'|trans }}</h1>
            <p class="mt-2 max-w-1xl text-2xl font-bold tracking-tight text-slate-950">{{ 'home.tagline'|trans }}</p>
            <div class="mt-8 grid gap-4 sm:grid-cols-3">
                <div class="bg-white rounded-lg border border-slate-200 p-5">
                    <p class="text-sm font-semibold text-slate-600">{{ 'home.metrics.completed_stages'|trans }}</p>
                    <p class="mt-2 text-3xl font-extrabold">{{ dashboard.completedStageCount }}/{{ dashboard.totalStageCount }}</p>
                </div>
                <div class="bg-white rounded-lg border border-slate-200 p-5">
                    <p class="text-sm font-semibold text-slate-600">{{ 'home.metrics.team_time'|trans }}</p>
                    <p class="mt-2 text-3xl font-extrabold">{{ dashboard.formattedTeamTotalTime|trans }}</p>
                </div>
                <div class="bg-white rounded-lg border border-slate-200 p-5">
                    <p class="text-sm font-semibold text-slate-600">{{ 'home.metrics.petit_toureur_rank'|trans }}</p>
                    <p class="mt-2 text-3xl font-extrabold">{{ dashboard.globalFantasyRank ? '#' ~ dashboard.globalFantasyRank : '-' }}</p>
                </div>
            </div>
        </div>
    </section>

    <section class="mx-auto grid max-w-6xl gap-6 px-4 py-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)]">
        <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-bold uppercase tracking-wide text-emerald-700">{{ 'home.team.eyebrow'|trans }}</p>
                    {% if dashboard.team %}
                        <h2 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-950">{{ dashboard.team.name }}</h2>
                        <p class="mt-1 text-sm font-semibold text-slate-600">{{ 'home.team.budget_used'|trans({'%budget%': dashboard.team.spentBudgetInEuros|number_format(0, ',', ' ')}) }}</p>
                    {% else %}
                        <h2 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-950">{{ 'home.team.title'|trans }}</h2>
                    {% endif %}
                </div>
                {% if dashboard.team is null %}
                    <a class="rounded-md bg-emerald-700 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-800" href="{{ path('team_create') }}">{{ 'home.team.compose'|trans }}</a>
                {% endif %}
            </div>

            {% if dashboard.team %}
                <div class="mt-6">
                    <ul class="mt-5 space-y-3">
                        {% for rider in dashboard.team.riders %}
                            <li class="flex items-center justify-between gap-3 border-t border-slate-100 pt-3 text-sm">
                                <span>
                                    <span class="block font-bold">
                                        {% if rider.nationalityFlag %}<span aria-hidden="true">{{ rider.nationalityFlag }}</span>{% endif %}
                                        {{ rider.name }}
                                    </span>
                                    <span class="mt-1 block text-xs font-semibold text-slate-600">
                                        {{ rider.specialty ?? 'rider.specialty.polyvalent'|trans }} · {{ rider.formattedTotalGap }}
                                        {% if not rider.isStillRacing %}
                                            <span class="ml-2 rounded bg-rose-100 px-2 py-0.5 text-[11px] font-extrabold uppercase text-rose-800">{{ 'rider.status.abandoned'|trans }}</span>
                                        {% endif %}
                                    </span>
                                </span>
                                <span class="text-slate-600">{{ rider.marketValueInEuros|number_format(0, ',', ' ') }} €</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% else %}
                <p class="mt-6 text-sm text-slate-600">{{ 'home.team.empty'|trans }}</p>
            {% endif %}
        </article>

        <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div>
                    <p class="text-sm font-bold uppercase tracking-wide text-emerald-700">{{ 'home.leagues.eyebrow'|trans }}</p>
                    <h2 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-950">{{ 'home.leagues.title'|trans }}</h2>
                </div>
                <div class="flex gap-2">
                    <a class="rounded-md bg-slate-950 px-4 py-2 text-sm font-bold text-white hover:bg-slate-800" href="{{ path('league_create') }}">{{ 'home.leagues.create'|trans }}</a>
                    <a class="rounded-md border border-slate-300 px-4 py-2 text-sm font-bold text-slate-800 hover:border-emerald-600 hover:text-emerald-700" href="{{ path('league_join') }}">{{ 'home.leagues.join'|trans }}</a>
                </div>
            </div>

            {% if dashboard.leagues is empty %}
                <p class="mt-6 text-sm text-slate-600">{{ 'home.leagues.empty'|trans }}</p>
            {% endif %}

            <div class="mt-6 space-y-6">
                {% for league in dashboard.leagues %}
                    <section class="border-t border-slate-200 pt-5">
                        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                            <h3 class="text-lg font-extrabold">{{ league.name }}</h3>
                            <div class="flex items-center gap-2">
                                <p class="rounded-md bg-emerald-50 px-3 py-1 text-sm font-extrabold text-emerald-800">{{ 'league.code'|trans({'%code%': league.code}) }}</p>
                                <a class="rounded-md bg-slate-950 px-3 py-1 text-sm font-bold text-white hover:bg-slate-800" href="{{ path('league_show', { id: league.id }) }}">{{ 'league.dashboard'|trans }}</a>
                            </div>
                        </div>
                        {% if league.standings is empty %}
                            <p class="mt-4 text-sm text-slate-600">{{ 'home.leagues.no_team'|trans }}</p>
                        {% else %}
                            <div class="mt-4 overflow-hidden rounded-lg border border-slate-200">
                                <table class="w-full text-left text-sm">
                                    <thead class="bg-slate-100 text-xs font-bold uppercase tracking-wide text-slate-600">
                                        <tr>
                                            <th class="px-4 py-3">{{ 'table.rank'|trans }}</th>
                                            <th class="px-4 py-3">{{ 'table.team'|trans }}</th>
                                            <th class="px-4 py-3">{{ 'table.manager'|trans }}</th>
                                            <th class="px-4 py-3">{{ 'table.cumulative_time'|trans }}</th>
                                            <th class="px-4 py-3">{{ 'table.gap'|trans }}</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-200">
                                        {% for standing in league.standings %}
                                            <tr class="{{ standing.isCurrentUser ? 'border-l-4 border-emerald-600 bg-emerald-50/80' : '' }}">
                                                <td class="px-4 py-3 font-extrabold">#{{ standing.rank }}</td>
                                                <td class="px-4 py-3 font-bold">{{ standing.teamName }}</td>
                                                <td class="px-4 py-3">{{ standing.ownerUsername }}</td>
                                                <td class="px-4 py-3 font-semibold">{{ standing.formattedTotalTime }}</td>
                                                <td class="px-4 py-3 font-semibold text-slate-600">{{ standing.formattedGap }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </section>
                {% endfor %}
            </div>
        </article>
    </section>
{% endblock %}
