{% extends 'base.html.twig' %}

{% block title %}Composer mon équipe - Mon Petit Tour{% endblock %}

{% block body %}
    <section class="mx-auto max-w-6xl px-4 py-10">
        <h1 class="text-3xl font-extrabold tracking-tight text-slate-950">Composer mon équipe</h1>
        <p class="mt-2 text-sm font-semibold text-slate-600">Choisis exactement 8 coureurs pour un budget maximum de 500 000 €.</p>

        {% if error %}
            <div class="mt-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-800">{{ error }}</div>
        {% endif %}

        {{ form_start(form, { attr: { class: 'mt-8 space-y-6', 'data-team-builder': '' }, action: path('team_create') }) }}
            <div>
                {{ form_label(form.name, 'Nom de l’équipe', { label_attr: { class: 'block text-sm font-semibold text-slate-800' } }) }}
                {{ form_widget(form.name, { attr: { class: 'mt-2 w-full max-w-xl rounded-md border border-slate-300 px-3 py-2 outline-none focus:border-emerald-600 focus:ring-2 focus:ring-emerald-100' } }) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="grid gap-4 md:grid-cols-2">
                {% for riderField in form.riders %}
                    {% set rider = form.riders.vars.choices[riderField.vars.value].data %}
                    <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-slate-200 bg-white p-4 hover:border-emerald-600">
                        {{ form_widget(riderField, { attr: { class: 'mt-1', 'data-rider-value': rider.marketValueInEuros } }) }}
                        <span class="min-w-0 flex-1">
                            <span class="block font-extrabold text-slate-950">{{ riderField.vars.label }}</span>
                            <span class="mt-1 block text-sm text-slate-600">{{ rider.realTeam }} · {{ rider.nationality }} · {{ rider.specialty ? rider.specialty.value : 'polyvalent' }}</span>
                        </span>
                        <span class="shrink-0 text-sm font-extrabold text-emerald-800">{{ rider.marketValueInEuros|number_format(0, ',', ' ') }} €</span>
                    </label>
                {% endfor %}
            </div>
            {{ form_errors(form.riders) }}

            <div class="sticky bottom-0 -mx-4 border-t border-slate-200 bg-white/95 px-4 py-4 backdrop-blur">
                <div class="mb-3 flex flex-col gap-2 text-sm font-semibold text-slate-700 sm:flex-row sm:items-center sm:justify-between">
                    <p><span data-selected-count>0</span>/8 coureurs sélectionnés</p>
                    <p><span data-selected-budget>0 €</span> / 500 000 €</p>
                </div>
                <p class="mb-3 text-sm font-semibold text-red-700" data-team-builder-message></p>
                <div class="flex gap-3">
                    <button class="rounded-md bg-emerald-700 px-5 py-3 text-sm font-bold text-white hover:bg-emerald-800 disabled:cursor-not-allowed disabled:bg-slate-300" type="submit" data-team-builder-submit>Enregistrer l’équipe</button>
                    <a class="rounded-md border border-slate-300 px-5 py-3 text-sm font-bold text-slate-800 hover:border-emerald-600 hover:text-emerald-700" href="{{ path('home') }}">Annuler</a>
                </div>
            </div>
        {{ form_end(form) }}
    </section>

    <script>
        (() => {
            const form = document.querySelector('[data-team-builder]');
            if (!form) {
                return;
            }

            const checkboxes = Array.from(form.querySelectorAll('input[name="riders[]"]'));
            const selectedCount = form.querySelector('[data-selected-count]');
            const selectedBudget = form.querySelector('[data-selected-budget]');
            const message = form.querySelector('[data-team-builder-message]');
            const submit = form.querySelector('[data-team-builder-submit]');
            const formatter = new Intl.NumberFormat('fr-FR');

            const refresh = () => {
                const checked = checkboxes.filter((checkbox) => checkbox.checked);
                const budget = checked.reduce((total, checkbox) => total + Number(checkbox.dataset.riderValue), 0);
                const countIsValid = checked.length === 8;
                const budgetIsValid = budget <= 500000;

                selectedCount.textContent = checked.length.toString();
                selectedBudget.textContent = `${formatter.format(budget)} €`;
                submit.disabled = !(countIsValid && budgetIsValid);

                if (!countIsValid) {
                    message.textContent = 'Sélectionne exactement 8 coureurs pour enregistrer ton équipe.';
                    return;
                }

                if (!budgetIsValid) {
                    message.textContent = 'Le budget maximum de 500 000 € est dépassé.';
                    return;
                }

                message.textContent = '';
            };

            checkboxes.forEach((checkbox) => checkbox.addEventListener('change', refresh));
            refresh();
        })();
    </script>
{% endblock %}
